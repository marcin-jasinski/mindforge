AI_PROVIDER=openrouter

OPENROUTER_API_KEY=your_openrouter_api_key_here

OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Small model — used for section detection, link classification (cheap & fast)
MODEL_SMALL=openai/gpt-4o-mini

# Large model — used only for final summarization (higher quality)
MODEL_LARGE=openai/gpt-4o

# Vision model — used for analyzing images/diagrams from lessons
MODEL_VISION=openai/gpt-4o

# Feature flags (true/false) — all enabled by default
ENABLE_IMAGE_ANALYSIS=true
ENABLE_FLASHCARDS=true
ENABLE_QUIZZES=true
ENABLE_DIAGRAMS=true
ENABLE_KNOWLEDGE_INDEX=true
ENABLE_VALIDATION=true

# ── Langfuse telemetry ──────────────────────────────────────────────────────
# Set ENABLE_TRACING=true to send traces to Langfuse.
# For local Docker stack: LANGFUSE_HOST=http://localhost:3100
# For cloud: LANGFUSE_HOST=https://cloud.langfuse.com
ENABLE_TRACING=false
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_HOST=http://localhost:3100

# ── Neo4j graph-RAG ────────────────────────────────────────────────────────
# Set ENABLE_GRAPH_RAG=true to index lessons into Neo4j and enable quiz-agent.
# Start Neo4j: docker compose --profile graph up -d
ENABLE_GRAPH_RAG=false
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password

# Embedding model for vector search (OpenAI-compatible endpoint)
MODEL_EMBEDDING=openai/text-embedding-3-small
# Set ENABLE_EMBEDDINGS=false to skip the vector search leg entirely and rely
# on graph + full-text search only (saves embedding API cost on every query).
ENABLE_EMBEDDINGS=true

# ── API / GUI (Phase 6) ────────────────────────────────────────────────────
# Discord OAuth2 for authentication
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:8080/api/auth/callback

# Secret key for signing JWT tokens (generate a random 32+ char string)
JWT_SECRET=

# Optional: restrict access to a single Discord user ID
ALLOWED_DISCORD_USER_ID=

# Set to true ONLY for local HTTP development (suppresses the Secure cookie flag).
# Leave unset or set to false for any HTTPS deployment.
LOCAL_DEV=true

# ── Discord Bot (Phase 8) ──────────────────────────────────────────
# Bot token from https://discord.com/developers/applications
DISCORD_BOT_TOKEN=

# Channel ID to send daily spaced-repetition due reminders (integer snowflake)
DISCORD_NOTIFICATION_CHANNEL_ID=

# UTC hour for the daily SR reminder (0–23, default 8 = 08:00 UTC)
NOTIFICATION_HOUR_UTC=8

# Maximum file size for /upload command in megabytes (default 5)
UPLOAD_MAX_SIZE_MB=5

# ── Discord Bot Access Control ────────────────────────────────────
# Comma-separated guild (server) snowflake IDs allowed to use the bot.
# Leave empty to skip guild-based restriction.
DISCORD_ALLOWED_GUILD_IDS=

# Comma-separated role snowflake IDs that may execute bot commands
# (checked together with guild membership; empty = no role restriction).
DISCORD_ALLOWED_ROLE_IDS=

# Comma-separated Discord user snowflake IDs that are always permitted
# regardless of guild or role.
DISCORD_ALLOWED_USER_IDS=

# Set to false ONLY for fully public bots with no sensitive data.
# When true (default) the bot refuses to start unless at least one
# allowlist above is non-empty.
DISCORD_REQUIRE_AUTH=true
