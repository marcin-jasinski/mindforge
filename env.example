# ────────────────────────────────────────────────────────────────────────────
# MindForge — Environment Configuration Template
#
# Copy this file to .env and fill in the values for your local setup.
# Required variables are marked [REQUIRED]. Optional ones have safe defaults.
# Settings are validated once at startup – never read at request time.
# ────────────────────────────────────────────────────────────────────────────

# ── Database ────────────────────────────────────────────────────────────────
# [REQUIRED] PostgreSQL connection string (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://mindforge:secret@localhost:5432/mindforge

# ── Redis ───────────────────────────────────────────────────────────────────
# Optional. Quiz sessions fall back to PostgreSQL when Redis is absent.
# SSE falls back to polling outbox_events. Semantic cache is disabled.
# A startup warning is emitted when Redis is absent.
REDIS_URL=redis://localhost:6379/0

# ── Neo4j ───────────────────────────────────────────────────────────────────
# Optional when ENABLE_GRAPH=false.
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=secret
NEO4J_DATABASE=neo4j

# ── AI Models ───────────────────────────────────────────────────────────────
# LiteLLM model strings. Override to use any supported provider/model.
# [REQUIRED] At least one of OPENROUTER_API_KEY or another provider key.
MODEL_SMALL=openai/gpt-4o-mini
MODEL_LARGE=openai/gpt-4o
MODEL_VISION=openai/gpt-4o
MODEL_EMBEDDING=openai/text-embedding-3-small
MODEL_FALLBACK=anthropic/claude-3-haiku-20240307
OPENROUTER_API_KEY=sk-or-...

# ── Local Models (uncomment to use Ollama instead of cloud) ─────────────────
# MODEL_SMALL=ollama/llama3.1
# MODEL_LARGE=ollama/llama3.1:70b
# MODEL_VISION=ollama/llava
# MODEL_EMBEDDING=ollama/nomic-embed-text
# OLLAMA_API_BASE=http://localhost:11434

# ── Auth — Discord OAuth ─────────────────────────────────────────────────────
# Required when ENABLE_DISCORD_AUTH=true (default).
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:8080/api/auth/callback/discord

# ── Auth — Google OAuth (future) ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Auth — GitHub OAuth (future) ─────────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Auth — Basic / Email + Password ──────────────────────────────────────────
# Set to false to disable email/password login.
ENABLE_BASIC_AUTH=true
BCRYPT_COST_FACTOR=12

# ── Auth — JWT & Cookies ─────────────────────────────────────────────────────
# [REQUIRED] Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=
JWT_ACCESS_TOKEN_TTL_MINUTES=60
JWT_REFRESH_TOKEN_TTL_DAYS=30
# Set to true in production (HTTPS required).
AUTH_SECURE_COOKIES=false

# ── Discord Bot ───────────────────────────────────────────────────────────────
# Required when running the Discord bot surface (mindforge-discord entry point).
DISCORD_BOT_TOKEN=
# Comma-separated Discord guild (server) IDs that are allowed to use the bot.
DISCORD_ALLOWED_GUILDS=

# ── Slack Bot ────────────────────────────────────────────────────────────────
# Required when running the Slack bot surface.
SLACK_BOT_TOKEN=xoxb-
SLACK_APP_TOKEN=xapp-
SLACK_SIGNING_SECRET=
# Comma-separated Slack workspace IDs that are allowed to use the bot.
SLACK_ALLOWED_WORKSPACES=

# ── Object Storage (MinIO / S3) ───────────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=mindforge-assets
# Set to true when using AWS S3 or a TLS-enabled MinIO instance.
MINIO_SECURE=false

# ── Feature Flags ─────────────────────────────────────────────────────────────
# Disable individual pipeline stages or subsystems without code changes.
ENABLE_GRAPH=true
ENABLE_IMAGE_ANALYSIS=true
ENABLE_FLASHCARDS=true
ENABLE_DIAGRAMS=true
ENABLE_TRACING=true
ENABLE_EMBEDDINGS=true
ENABLE_RELEVANCE_GUARD=true
# Set to false to skip the ArticleFetcher pipeline stage (no outbound HTTP fetches).
ENABLE_ARTICLE_FETCH=true

# ── Limits ───────────────────────────────────────────────────────────────────
MAX_DOCUMENT_SIZE_MB=10
MAX_CONCURRENT_PIPELINES=2
MAX_PENDING_TASKS_PER_USER=10
# Minutes before a running pipeline task is considered stale and re-claimable.
PIPELINE_TASK_STALE_THRESHOLD_MINUTES=30
# Seconds before an idle quiz session expires.
QUIZ_SESSION_TTL_SECONDS=1800

# ── Chunking ──────────────────────────────────────────────────────────────────
CHUNK_MAX_TOKENS=512
CHUNK_MIN_TOKENS=64
CHUNK_OVERLAP_TOKENS=64

# ── Observability — Langfuse ─────────────────────────────────────────────────
# Required when ENABLE_TRACING=true.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000
